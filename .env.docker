DATABASE_URL=postgresql://postgres:postgres@jobscope-db:5432/jobscope

APP_ENV=docker
LOG_LEVEL=INFO

DB_POOL_PRE_PING=true
DB_POOL_RECYCLE_SECONDS=1800
DB_CONNECT_TIMEOUT_SECONDS=5

DATA_DIR=data
PROCESSED_DIR=data/processed

RAG_USE_LLM=false
LLM_API_URL=
LLM_API_KEY=
LLM_MODEL=
LLM_TIMEOUT_SECONDS=20

DO_NOT_TRACK=1
PREFECT_SERVER_ANALYTICS_ENABLED=false